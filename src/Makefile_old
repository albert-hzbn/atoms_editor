#
# Cross Platform Makefile
# Compatible with Linux / MSYS2 / Mac
#

EXE = imgui_demo

IMGUI_DIR = ../

SOURCES = main.cpp

SOURCES += $(IMGUI_DIR)/imgui/imgui.cpp \
           $(IMGUI_DIR)/imgui/imgui_demo.cpp \
           $(IMGUI_DIR)/imgui/imgui_draw.cpp \
           $(IMGUI_DIR)/imgui/imgui_tables.cpp \
           $(IMGUI_DIR)/imgui/imgui_widgets.cpp

SOURCES += $(IMGUI_DIR)/backends/imgui_impl_glfw.cpp \
           $(IMGUI_DIR)/backends/imgui_impl_opengl3.cpp

OBJS = $(addsuffix .o,$(basename $(notdir $(SOURCES))))

UNAME_S := $(shell uname -s)

CXXFLAGS = -std=c++11 -I$(IMGUI_DIR)/imgui -I$(IMGUI_DIR)/backends
CXXFLAGS += -g -Wall -Wformat

LIBS =

# --------------------------------------------------
# PLATFORM FLAGS
# --------------------------------------------------

ifeq ($(UNAME_S), Linux)

ECHO_MESSAGE = "Linux"

CXXFLAGS += `pkg-config --cflags glfw3`

LIBS += `pkg-config --libs glfw3`
LIBS += -lGLEW -lGL -ldl -lpthread

endif

# --------------------------------------------------
# BUILD RULES
# --------------------------------------------------

%.o:%.cpp
	$(CXX) $(CXXFLAGS) -c -o $@ $<

%.o:$(IMGUI_DIR)/imgui/%.cpp
	$(CXX) $(CXXFLAGS) -c -o $@ $<

%.o:$(IMGUI_DIR)/backends/%.cpp
	$(CXX) $(CXXFLAGS) -c -o $@ $<

all: $(EXE)
	@echo Build complete for $(ECHO_MESSAGE)

$(EXE): $(OBJS)
	$(CXX) -o $@ $^ $(LIBS)

clean:
	rm -f $(EXE) $(OBJS)